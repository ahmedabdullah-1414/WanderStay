<% layout("/layouts/boilerplate") -%>

<div class="auth-wrapper">
  <div class="auth-card">
    <div class="auth-header">
      <i class="fa-regular fa-compass auth-logo"></i>
      <h2 class="auth-title">Welcome back</h2>
      <p class="auth-subtitle">Log in to your Wanderstay account</p>
    </div>

    <form action="/login" method="POST" class="needs-validation" novalidate>
      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input type="text" placeholder="Enter your username" name="username" id="username" class="form-control airbnb-input" required>
        <div class="invalid-feedback">Please enter your username.</div>
      </div>

      <div class="mb-4">
        <label for="password" class="form-label">Password</label>
        <input type="password" placeholder="Enter your password" name="password" id="password" class="form-control airbnb-input" required>
        <div class="invalid-feedback">Please enter your password.</div>
      </div>

      <button class="btn airbnb-btn w-100">Log in</button>
    </form>

    <p class="auth-footer">Don't have an account? <a href="/signup">Sign up</a></p>
  </div>
</div>
