<% layout("/layouts/boilerplate") %>
<% const adminPage = "listings" %>
<link rel="stylesheet" href="/css/admin.css">

<div class="admin-layout">
  <%- include("../includes/adminSidebar") %>
  <main class="admin-main">
    <div class="admin-topbar">
      <h1 class="admin-page-title">Listings <span class="admin-count">(<%= total %>)</span></h1>
      <form class="admin-search-form" method="GET" action="/admin/listings">
        <input type="text" name="search" value="<%= search %>" placeholder="Search by title or location..." class="admin-search-input">
        <button class="btn admin-search-btn">Search</button>
      </form>
    </div>

    <div class="admin-card">
      <table class="admin-table">
        <thead>
          <tr><th>Image</th><th>Title</th><th>Location</th><th>Owner</th><th>Price</th><th>Category</th><th>Actions</th></tr>
        </thead>
        <tbody>
          <% listings.forEach(listing => { %>
          <tr>
            <td><img src="<%= listing.image.url %>" class="admin-thumb" alt=""></td>
            <td><strong><%= listing.title %></strong></td>
            <td><%= listing.location %>, <%= listing.country %></td>
            <td><%= listing.owner ? listing.owner.username : "—" %></td>
            <td>&#8377;<%= listing.price.toLocaleString("en-IN") %></td>
            <td><span class="badge-blue"><%= listing.category || "—" %></span></td>
            <td class="action-cell">
              <a href="/listings/<%= listing._id %>" class="btn admin-action-btn btn-view" target="_blank">View</a>
              <form action="/admin/listings/<%= listing._id %>?_method=DELETE" method="POST" style="display:inline"
                    onsubmit="return confirm('Delete this listing?')">
                <button class="btn admin-action-btn btn-delete">Delete</button>
              </form>
            </td>
          </tr>
          <% }) %>
          <% if (!listings.length) { %>
          <tr><td colspan="7" class="text-center text-muted">No listings found.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <%- include("../includes/adminPagination", { page, totalPages, baseUrl: "/admin/listings", query: { search } }) %>
  </main>
</div>
