<% layout("/layouts/boilerplate") %>

<div class="form-page-wrapper">
  <div class="form-card">
    <div class="form-card-header">
      <h2 class="form-card-title">List your place</h2>
      <p class="form-card-subtitle">Share your space with travellers around the world</p>
    </div>

    <form action="/listings" method="POST" class="needs-validation" novalidate enctype="multipart/form-data">

      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input type="text" name="listing[title]" placeholder="e.g. Cozy beachfront cottage" class="form-control airbnb-input" required>
        <div class="invalid-feedback">Please add a title.</div>
      </div>

      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea name="listing[description]" placeholder="Describe your place — what makes it special?" class="form-control airbnb-input" rows="4" required></textarea>
        <div class="invalid-feedback">Please add a description.</div>
      </div>

      <div class="mb-3">
        <label for="image" class="form-label">Photos</label>
        <div class="upload-area">
          <i class="fa-regular fa-image upload-icon"></i>
          <p class="upload-text">Click to upload or drag and drop</p>
          <input type="file" name="image" class="upload-input" required accept="image/*">
        </div>
      </div>

      <div class="row">
        <div class="mb-3 col-md-4">
          <label for="price" class="form-label">Price per night (₹)</label>
          <input type="number" name="listing[price]" placeholder="0" class="form-control airbnb-input" required>
          <div class="invalid-feedback">Please add a price.</div>
        </div>
        <div class="mb-3 col-md-8">
          <label for="location" class="form-label">Location</label>
          <input type="text" name="listing[location]" placeholder="City, State" class="form-control airbnb-input" required>
          <div class="invalid-feedback">Please add a location.</div>
        </div>
      </div>

      <div class="mb-4">
        <label for="country" class="form-label">Country</label>
        <input type="text" name="listing[country]" placeholder="Country" class="form-control airbnb-input" required>
        <div class="invalid-feedback">Please add a country.</div>
      </div>

      <div class="mb-4">
        <label for="category" class="form-label">Category</label>
        <select name="listing[category]" class="form-control airbnb-input" required>
          <option value="" disabled selected>Select a category</option>
          <option value="Trending">Trending</option>
          <option value="Rooms">Rooms</option>
          <option value="Iconic Cities">Iconic Cities</option>
          <option value="Mountains">Mountains</option>
          <option value="Castles">Castles</option>
          <option value="Amazing Pools">Amazing Pools</option>
          <option value="Arctic">Arctic</option>
          <option value="Domes">Domes</option>
          <option value="Boats">Boats</option>
          <option value="Camping">Camping</option>
          <option value="Farms">Farms</option>
        </select>
        <div class="invalid-feedback">Please select a category.</div>
      </div>

      <button class="btn airbnb-btn w-100">Publish listing</button>
    </form>
  </div>
</div>
