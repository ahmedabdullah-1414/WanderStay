<% layout("/layouts/boilerplate") %>

<div class="my-bookings-page">
  <h2 class="my-bookings-title">
    <i class="fa-solid fa-heart" style="color:#fe424d;margin-right:0.5rem"></i>Saved Listings
  </h2>

  <% if (listings.length === 0) { %>
    <div class="no-results">
      <i class="fa-regular fa-heart"></i>
      <p>You haven't saved any listings yet.</p>
      <a href="/listings" class="btn airbnb-btn mt-3">Explore listings</a>
    </div>
  <% } else { %>
    <div class="listings-grid">
      <% for (let listing of listings) { %>
      <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="listing-card">
          <div class="listing-img-wrap">
            <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="listing-img" />
            <button class="wishlist-btn saved"
                    data-id="<%= listing._id %>"
                    aria-label="Remove from wishlist"
                    onclick="toggleWishlist(event, this)">
              <i class="fa-solid fa-heart"></i>
            </button>
          </div>
          <div class="listing-info">
            <div class="listing-title-row">
              <span class="listing-title"><%= listing.title %></span>
              <span class="listing-rating"><i class="fa-solid fa-star"></i> 4.9</span>
            </div>
            <p class="listing-location text-muted"><%= listing.location %>, <%= listing.country %></p>
            <p class="listing-price"><span>&#8377;<%= listing.price.toLocaleString("en-IN") %></span> / night</p>
          </div>
        </div>
      </a>
      <% } %>
    </div>
  <% } %>
</div>

<script>
async function toggleWishlist(e, btn) {
  e.preventDefault();
  e.stopPropagation();
  const id = btn.dataset.id;
  const res = await fetch(`/wishlist/${id}/toggle`, { method: "POST" });
  const data = await res.json();
  if (!data.saved) {
    // remove card from page instantly
    btn.closest("a").remove();
    // show empty state if no cards left
    if (!document.querySelector(".listing-card")) {
      document.querySelector(".listings-grid").innerHTML = `
        <div class="no-results" style="grid-column:1/-1">
          <i class="fa-regular fa-heart"></i>
          <p>You haven't saved any listings yet.</p>
          <a href="/listings" class="btn airbnb-btn mt-3">Explore listings</a>
        </div>`;
    }
  }
}
</script>
